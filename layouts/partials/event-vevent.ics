{{- /*
  Hugo British Scout Group theme
  CC BY-SA 4.0 © Peter Mahon
  https://github.com/petemahon/hugo-british-scout-group

  event-vevent.ics - emit a single VEVENT for a Page.

  Receives a Page via dot.

  D8 status-model changes
  -----------------------
  Status enum (replacing the old `cancelled` boolean):

    active     normal emission
    postponed  emitted with new date; DESCRIPTION prefixed with the
               i18n note; SEQUENCE bumped to max(1, .Params.revision)
               so calendar subscribers' apps update the meeting in
               place rather than duplicating
    cancelled  THIS PARTIAL EMITS NOTHING. Caller (per-event .ics
               template, aggregate .ics template) is responsible for
               skipping the partial call for cancelled events.

  The cancelled-omission rule means a cancelled event:
    - Has an event.ics file containing an empty (well-formed)
      VCALENDAR wrapper - the URL keeps working but contains no
      VEVENT, so a calendar app polling the URL removes the meeting.
    - Is omitted from the aggregate /events/all.ics feed.

  Old behaviour (STATUS:CANCELLED in the feed) is retired - SPEC-02
  acceptance criteria 4 and 7 reworded accordingly. See documentation.

  RFC 5545 fields emitted:
    BEGIN:VEVENT
    UID            <slug>@<host>
    DTSTAMP        build time, UTC
    DTSTART/DTEND  local timezone for timed events; VALUE=DATE for all-day
    SUMMARY        title, RFC-escaped
    DESCRIPTION    summary | first 500 chars of body, RFC-escaped,
                   prefixed when postponed
    LOCATION       location field, RFC-escaped
    URL            page permalink
    SEQUENCE       0 default; revision field if set; ≥1 if postponed
    END:VEVENT
*/ -}}
{{- $page := . -}}
{{- $status := $page.Params.status | default "active" -}}
{{- if ne $status "cancelled" -}}

  {{- $crlf := "\r\n" -}}
  {{- $tz   := $page.Params.timezone | default site.Params.events.timezone | default "Europe/London" -}}
  {{- $start := $page.Date -}}
  {{- $end   := $page.Params.end | default ($start.Add (time.Duration "minute" 90)) -}}
  {{- if not ($end | time) -}}
    {{- $end = $start.Add (time.Duration "minute" 90) -}}
  {{- end -}}
  {{- $end = ($end | time) -}}

  {{- /* All-day VEVENTs use VALUE=DATE and an exclusive DTEND, shifted
         by 24 h so a single-day event whose front-matter has date and
         end equal still emits a valid one-day event. */ -}}
  {{- if $page.Params.all_day -}}
    {{- $end = $end.Add (time.Duration "hour" 24) -}}
  {{- end -}}

  {{- /* UID host = host portion of site.BaseURL. Stable across rebuilds. */ -}}
  {{- $host := "" -}}
  {{- with site.BaseURL -}}
    {{- $host = (urls.Parse .).Host -}}
  {{- end -}}
  {{- $uid := printf "%s@%s" $page.File.ContentBaseName $host -}}

  {{- /* RFC 5545 §3.3.11 text escaping: \, ;, ,, and newlines.
         Order matters: backslash MUST be escaped first. */ -}}
  {{- $summary := $page.Title -}}
  {{- $summary = $summary | replaceRE `\\` `\\\\` | replaceRE `;` `\;` | replaceRE `,` `\,` | replaceRE "\n" `\n` -}}

  {{- $description := $page.Params.summary -}}
  {{- if not $description -}}
    {{- $description = $page.Plain | truncate 500 -}}
  {{- end -}}
  {{- if eq $status "postponed" -}}
    {{- $note := i18n "eventsPostponedICSNote" | default "Note: new date/time. " -}}
    {{- $description = print $note $description -}}
  {{- end -}}
  {{- $description = $description | replaceRE `\\` `\\\\` | replaceRE `;` `\;` | replaceRE `,` `\,` | replaceRE "\n" `\n` -}}

  {{- $location := $page.Params.location | default "" -}}
  {{- $location = $location | replaceRE `\\` `\\\\` | replaceRE `;` `\;` | replaceRE `,` `\,` | replaceRE "\n" `\n` -}}

  {{- /* SEQUENCE: zero for active; revision number if set; bumped to ≥1
         for postponed events even if the author hasn't set revision. */ -}}
  {{- $sequence := int ($page.Params.revision | default 0) -}}
  {{- if and (eq $status "postponed") (lt $sequence 1) -}}
    {{- $sequence = 1 -}}
  {{- end -}}

  {{- $now := now -}}
BEGIN:VEVENT{{ $crlf -}}
UID:{{ $uid }}{{ $crlf -}}
DTSTAMP:{{ $now.UTC.Format "20060102T150405Z" }}{{ $crlf -}}
SEQUENCE:{{ $sequence }}{{ $crlf -}}
{{- if $page.Params.all_day -}}
DTSTART;VALUE=DATE:{{ $start.Format "20060102" }}{{ $crlf -}}
DTEND;VALUE=DATE:{{ $end.Format "20060102" }}{{ $crlf -}}
{{- else -}}
DTSTART;TZID={{ $tz }}:{{ $start.Format "20060102T150405" }}{{ $crlf -}}
DTEND;TZID={{ $tz }}:{{ $end.Format "20060102T150405" }}{{ $crlf -}}
{{- end -}}
SUMMARY:{{ $summary }}{{ $crlf -}}
{{- with $description -}}
DESCRIPTION:{{ . }}{{ $crlf -}}
{{- end -}}
{{- with $location -}}
LOCATION:{{ . }}{{ $crlf -}}
{{- end -}}
URL:{{ $page.Permalink }}{{ $crlf -}}
END:VEVENT{{ $crlf -}}

{{- end -}}
