{{- /*
  Hugo British Scout Group theme
  CC BY-SA 4.0 © Peter Mahon
  https://github.com/petemahon/hugo-british-scout-group

  Aggregate /events/all.ics - every upcoming non-cancelled event in
  one VCALENDAR. Output format: EventsAggregateCalendar (declared in
  hugo.toml).

  D8 status-model change
  ----------------------
  Cancelled events are OMITTED from the aggregate feed entirely (no
  VEVENT, no STATUS:CANCELLED line). When an event is cancelled, it
  disappears from the feed; calendar apps polling the URL will then
  remove the corresponding meeting from the subscriber's calendar on
  next refresh. This is the cleanest UX for parents.

  Postponed events ARE included - with their NEW DTSTART/DTEND, a
  prepended DESCRIPTION note, and SEQUENCE bumped so subscriber apps
  update the meeting in place.

  RFC 5545 compliant: UTF-8, CRLF line endings, one VEVENT per active
  or postponed upcoming event.
*/ -}}
{{- $crlf := "\r\n" -}}
{{- $now := now -}}
{{- $events := where site.RegularPages "Section" "events" -}}
{{- $events = where $events "Date" ">=" $now -}}
{{- $events = $events.ByDate -}}
BEGIN:VCALENDAR{{ $crlf -}}
VERSION:2.0{{ $crlf -}}
PRODID:-//Hugo British Scout Group theme//EN{{ $crlf -}}
CALSCALE:GREGORIAN{{ $crlf -}}
METHOD:PUBLISH{{ $crlf -}}
{{- range $events -}}
  {{- /* Skip cancelled events. event-vevent.ics is also defensive
         and emits nothing for cancelled status, but filtering here
         saves the partial call and keeps the intent clear. */ -}}
  {{- $status := .Params.status | default "active" -}}
  {{- if ne $status "cancelled" -}}
    {{- partial "event-vevent.ics" . -}}
  {{- end -}}
{{- end -}}
END:VCALENDAR{{ $crlf -}}
